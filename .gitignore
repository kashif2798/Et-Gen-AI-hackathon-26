# ───────────────────────────────────────────────────────────────────
# Databases (Vector Store, SQLite)
# ───────────────────────────────────────────────────────────────────
# Qdrant Vector Database
backend/et_nexus_db/
backend/et_nexus_db/*
*.sqlite
*.sqlite3
*.db

# But keep the structure for reference
!backend/et_nexus_db/.gitkeep

# ───────────────────────────────────────────────────────────────────
# Generated Files (Videos, Audio, Logs)
# ───────────────────────────────────────────────────────────────────
