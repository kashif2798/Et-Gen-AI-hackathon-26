backend/static/video/*.mp3
backend/static/video/*.mp4
backend/static/video/*.vtt
backend/static/video/*.json

# Keep directory structure
!backend/static/video/.gitkeep

# Logs
*.log
logs/
backend/*.log
backend/server_log.txt

